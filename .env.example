# Job Search 2026 — Environment Configuration
# Copy this file to .env and fill in your paths.
# .env is gitignored and never committed.
# Normally generated by: bash scripts/setup.sh

# Applicant's full name (used to name directories and pre-fill applicant.md)
export APPLICANT_NAME="First Last"

# Process repo (this repo — git-tracked)
export APP_DIR="/path/to/Job-Search-2026"

# Applicant data directory (PII, applications, profiles — NOT git-tracked)
# Generated by setup.sh as: <Documents>/job-applicant-<first-last>
export APPLICANT_DIR="/path/to/Documents/job-applicant-first-last"

# Google Drive sync target — omitted if Google Drive is not installed locally
# Generated by setup.sh as: <GDrive My Drive>/job-applicant-<first-last>
#
# macOS (Google Drive desktop app):
#   ~/Library/CloudStorage/GoogleDrive-yourname@gmail.com/My Drive/job-applicant-first-last
#
# Windows (Google Drive desktop app, PowerShell/WSL):
#   /mnt/g/My Drive/job-applicant-first-last     (WSL with drive mounted as G:)
#   C:/Users/yourname/Google Drive/job-applicant-first-last   (native Windows path)
#
# Linux (rclone mount):
#   /home/yourname/gdrive/job-applicant-first-last
#
# Find your macOS path:
#   ls ~/Library/CloudStorage/
#   — look for the GoogleDrive-[email] directory
#
export GDRIVE_DIR="/path/to/gdrive/job-applicant-first-last"

# Anthropic API key — only needed if NOT using Claude Code OAuth
#
# If you have logged in via 'claude auth login' (desktop app, VS Code, JetBrains,
# or 'claude auth login' in the terminal), leave this commented out.
#
# If you are using the Claude CLI in terminal-only mode without OAuth, set this.
# setup.sh detects OAuth status automatically and only prompts if needed.
# Get your key at https://console.anthropic.com/
#
# export ANTHROPIC_API_KEY="sk-ant-..."
