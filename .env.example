# Job Search 2026 — Environment Configuration
# Copy this file to .env and fill in your paths.
# .env is gitignored and never committed.

# Process repo (this repo — git-tracked)
export APP_DIR="/path/to/Job-Search-2026"

# Applicant data repo (PII, applications, profiles — NOT git-tracked)
export APPLICANT_DIR="/path/to/Job-Search-Applicant"

# Google Drive sync target
#
# macOS (Google Drive desktop app):
#   ~/Library/CloudStorage/GoogleDrive-yourname@gmail.com/My Drive/Job Search 2026
#
# Windows (Google Drive desktop app, PowerShell/WSL):
#   /mnt/g/My Drive/Job Search 2026          (WSL with drive mounted as G:)
#   C:/Users/yourname/Google Drive/Job Search 2026   (native Windows path)
#
# Linux (rclone mount):
#   /home/yourname/gdrive/Job Search 2026
#
# Find your macOS path:
#   ls ~/Library/CloudStorage/
#   — look for the GoogleDrive-[email] directory
#
export GDRIVE_DIR="/path/to/gdrive/Job Search 2026"
