# Job Search 2026 — Environment Configuration
# Copy this file to .env and fill in your paths.
# .env is gitignored and never committed.
# Normally generated by: bash scripts/setup.sh

# Applicant's full name (used to name directories and pre-fill applicant.md)
export APPLICANT_NAME="First Last"

# Process repo (this repo — git-tracked)
export APP_DIR="/path/to/Job-Search-2026"

# Applicant data directory (PII, applications, profiles — NOT git-tracked)
# Generated by setup.sh based on your storage choice:
#
# Local only (default):
#   ~/Documents/job-applications
#
# Inside a cloud sync service's managed folder (auto-synced by the OS):
#   ~/Library/CloudStorage/GoogleDrive-yourname@gmail.com/My Drive/job-applications
#   ~/Library/CloudStorage/OneDrive-Personal/job-applications
#   ~/Library/Mobile Documents/com~apple~CloudDocs/job-applications
#   ~/Dropbox/job-applications
#   ~/Box/job-applications
#
export APPLICANT_DIR="/path/to/job-applications"

# Python interpreter with Playwright installed — used by scripts/fetch-jd.py
# (fetching login-walled job pages) and scripts/generate-pdf.py (resume PDF
# generation). Set once by setup.sh; always used via $PLAYWRIGHT_PYTHON.
#
# Setup (once per machine):
#   pip install playwright && playwright install chromium
#   Then set this to whichever python has playwright:
#     python3 -c "import playwright" && echo "this python works"
#
# Per-site auth (once per site):
#   python3 scripts/fetch-jd.py --setup 'https://www.linkedin.com/jobs/view/123'
#   → opens a browser → you log in → press Enter → auth saved to .auth/
#
export PLAYWRIGHT_PYTHON="python3"

# Developer mode — controls whether Claude can edit files in $APP_DIR.
#
# false (default): $APP_DIR is read-only. Claude can only write to $APPLICANT_DIR.
# true:            Both $APP_DIR and $APPLICANT_DIR are writable.
#                  Use only when intentionally modifying the process/tooling repo.
#
# Toggle: edit .env and change "false" to "true" (no restart needed — hook re-reads .env per call)
#
export DEV_MODE="false"

# SearchAPI key — used by scripts/search-jobs.py for /ingest command
# Get your key at https://www.searchapi.io/
#
export SEARCHAPI_KEY="your_searchapi_key_here"

# /ingest tuning
# SEARCH_TARGET_FITS — target number of fit job stubs to create per /ingest run (default: 10)
# SEARCH_BATCH_SIZE  — jobs per API page / Haiku screening batch (default: 10)
#
export SEARCH_TARGET_FITS="10"
export SEARCH_BATCH_SIZE="10"

# Anthropic API key — only needed if NOT using Claude Code OAuth
#
# If you have logged in via 'claude auth login' (desktop app, VS Code, JetBrains,
# or 'claude auth login' in the terminal), leave this commented out.
#
# If you are using the Claude CLI in terminal-only mode without OAuth, set this.
# setup.sh detects OAuth status automatically and only prompts if needed.
# Get your key at https://console.anthropic.com/
#
# export ANTHROPIC_API_KEY="sk-ant-..."

# ---------------------------------------------------------------------------
# OB1 Integration — fill in after K8s cluster is running
# See integrations/ob1/README.md for setup instructions.
# ---------------------------------------------------------------------------

# Path to your local OB1 repository checkout — used to build the openbrain-mcp-server Docker image.
# Clone OB1 from: https://github.com/nicholasgasior/open-brain (or your fork)
export OB1_REPO_PATH="/path/to/OB1"

# Object store backend: 'minio' (local K8s) or 'supabase' (cloud)
export OBJECT_STORE_BACKEND="minio"

# MinIO S3 — NodePort service; accessible at localhost:30900 without port-forwarding
export MINIO_ENDPOINT="localhost:30900"
export MINIO_ACCESS_KEY="your_minio_access_key"
export MINIO_SECRET_KEY="your_minio_secret_key"
export MINIO_BUCKET="job-search"
export MINIO_SECURE="false"

# PostgreSQL — cluster-internal only; use port-forward on demand for admin access
export DB_HOST="localhost"
export DB_PORT="5432"
export DB_NAME="openbrain"
export DB_USER="postgres"
export DB_PASSWORD="your_postgres_password"

# OB1 MCP server — routed via nginx Ingress at /ob1 (no port-forward needed)
export OB1_MCP_URL="http://localhost/ob1"
export OB1_MCP_KEY="your_ob1_mcp_access_key"

# Job Search MCP service — routed via nginx Ingress at /job-search (no port-forward needed)
export JOB_SEARCH_MCP_URL="http://localhost/job-search"
export JOB_SEARCH_MCP_KEY="your_job_search_mcp_access_key"

# LLM API key — used by job-search-mcp and OB1 for embeddings + chat
# Works with OpenRouter or OpenAI directly (same variable, different key value)
# OpenRouter: https://openrouter.ai/ → Dashboard → API Keys
# OpenAI:     https://platform.openai.com/api-keys
export LLM_API_KEY="your_llm_api_key_here"

# LLM API endpoints and models
# Defaults below use OpenRouter. To use OpenAI directly, change to:
#   EMBEDDING_API_BASE=https://api.openai.com/v1   EMBEDDING_MODEL=text-embedding-3-small
#   CHAT_API_BASE=https://api.openai.com/v1         CHAT_MODEL=gpt-4o-mini
export EMBEDDING_API_BASE="https://openrouter.ai/api/v1"
export EMBEDDING_MODEL="openai/text-embedding-3-small"
export CHAT_API_BASE="https://openrouter.ai/api/v1"
export CHAT_MODEL="openai/gpt-4o-mini"

# Supabase (cloud alternative to MinIO — fill in only if OBJECT_STORE_BACKEND=supabase)
# export SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# export SUPABASE_SERVICE_KEY="your_supabase_service_key"
# export SUPABASE_BUCKET="job-search"
