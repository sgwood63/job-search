# Job Search 2026 — Storage Service Credentials
# Copy this file to .env.services and fill in your values.
# .env.services is gitignored and never committed.
#
# IMPORTANT: Do NOT source this file in Claude Code's shell session.
# These credentials give direct access to the underlying storage layer (MinIO,
# Postgres, LLM APIs). Claude must access all applicant data through the OB1
# MCP tools (which already have the credentials) — never directly.
#
# Sourced by:
#   scripts/start-ob1.sh      — before running OB1 docker-compose
#   scripts/k8s-apply-env.sh  — to populate K8s Secrets

# ---------------------------------------------------------------------------
# PostgreSQL — cluster-internal; port-forward on demand for direct access
# ---------------------------------------------------------------------------
export DB_HOST="localhost"
export DB_PORT="5432"
export DB_NAME="openbrain"
export DB_USER="postgres"
export DB_PASSWORD="your_postgres_password"

# ---------------------------------------------------------------------------
# Object store backend: 'minio' (local K8s/compose) or 'supabase' (cloud)
# ---------------------------------------------------------------------------
export OBJECT_STORE_BACKEND="minio"

# MinIO S3 — NodePort service; accessible at localhost:30900 without port-forwarding
# Docker Compose mode: set MINIO_ENDPOINT=minio:9000 (compose service name)
export MINIO_ENDPOINT="localhost:30900"
export MINIO_ACCESS_KEY="your_minio_access_key"
export MINIO_SECRET_KEY="your_minio_secret_key"
export MINIO_BUCKET="job-search"
export MINIO_SECURE="false"

# Supabase (cloud alternative to MinIO — fill in only if OBJECT_STORE_BACKEND=supabase)
# export SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# export SUPABASE_SERVICE_KEY="your_supabase_service_key"
# export SUPABASE_BUCKET="job-search"

# ---------------------------------------------------------------------------
# LLM APIs — used by job-search-mcp and openbrain-mcp for embeddings + chat
# ---------------------------------------------------------------------------
# Works with OpenRouter or OpenAI directly (same variable, different key value)
# OpenRouter: https://openrouter.ai/ → Dashboard → API Keys
# OpenAI:     https://platform.openai.com/api-keys
export LLM_API_KEY="your_llm_api_key_here"

# API endpoints and models
# Defaults below use OpenRouter. To use OpenAI directly:
#   EMBEDDING_API_BASE=https://api.openai.com/v1   EMBEDDING_MODEL=text-embedding-3-small
#   CHAT_API_BASE=https://api.openai.com/v1         CHAT_MODEL=gpt-4o-mini
export EMBEDDING_API_BASE="https://openrouter.ai/api/v1"
export EMBEDDING_MODEL="openai/text-embedding-3-small"
export CHAT_API_BASE="https://openrouter.ai/api/v1"
export CHAT_MODEL="openai/gpt-4o-mini"

# ---------------------------------------------------------------------------
# Container-only: Anthropic API key for Claude sessions inside containers
# Not needed for local Claude Code (uses OAuth). Required for docker-compose
# and K8s deployments where OAuth is not available.
# Get your key at https://console.anthropic.com/
# ---------------------------------------------------------------------------
export ANTHROPIC_API_DEPLOYMENT_KEY="sk-ant-..."

# ---------------------------------------------------------------------------
# OB1 repo path — used only for building the openbrain-mcp-server Docker image.
# Clone OB1 from: https://github.com/nicholasgasior/open-brain (or your fork)
# ---------------------------------------------------------------------------
export OB1_REPO_PATH="/path/to/OB1"
