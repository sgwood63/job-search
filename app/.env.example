# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual key or paths.

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Path to the applicant data directory (outside the app source tree, not git-tracked).
# Contains: applicant.md, application-tracker.md, profiles/, applications/, base-documents/, memory/
APPLICANT_DIR=/path/to/your/applicant/data
