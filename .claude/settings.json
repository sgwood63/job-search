{
  "statusLine": {
    "type": "command",
    "command": "bash /Users/shermanwood/Documents/Job-Search-2026/scripts/status-line.sh",
    "refreshInterval": 300
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "bash scripts/check-dev-mode.sh" }]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "bash scripts/check-dev-mode.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "bash scripts/summarize-write.sh" }]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" && bash scripts/sync-memory.sh'"
          },
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" && bash scripts/generate-setup-status.sh'"
          }
        ]
      }
    ]
  }
}
