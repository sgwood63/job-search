{
  "permissions": {
    "allow": [
      "Bash(curl -si http://localhost:8000/applications/2026-06-06-stealth-clinical-ai-biz-ops-lead)",
      "Bash(kubectl apply *)",
      "Bash(echo \"PF_PID=$!\")",
      "Bash(docker build *)",
      "Bash(kubectl exec *)",
      "Bash(.venv/bin/pytest tests/ -x -q)",
      "Bash(.venv/bin/pytest tests/test_api.py::test_health_ok -x -q)",
      "Bash(.venv/bin/pytest tests/ -q --ignore=tests/test_api.py)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-dev-mode.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-dev-mode.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/summarize-write.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" && bash scripts/sync-memory.sh'"
          },
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" && bash scripts/generate-setup-status.sh'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash scripts/status-line.sh",
    "refreshInterval": 300
  }
}
